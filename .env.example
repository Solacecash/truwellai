# Copy to mobile/.env (never commit secrets).



# Project URL must be origin only (https://yourref.supabase.co) — no /rest/v1 path.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co

EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key



# Native Google Sign-In (Web OAuth client ID from Google Cloud Console; not the Android/iOS client ID).

# Required for onboarding account Google sign-in and `signInWithIdToken` with Supabase.

# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=



# Stripe PaymentSheet / telehealth card flows only. In-app subscriptions use Adapty (lib/adapty.ts).

# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx



# Set to 1 only for local Supabase / LAN (http + private IPs allowed in dev). Never in production EAS.

# EXPO_PUBLIC_ALLOW_LOCAL_SUPABASE=1



# In-app subscriptions: Adapty public SDK key is in lib/adapty.ts (not env-based today).

# Dev-only: unlock premium gates for app review (never true in production EAS).
# EXPO_PUBLIC_TEST_MODE=true

