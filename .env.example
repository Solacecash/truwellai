# Copy to mobile/.env (never commit secrets).



# Project URL must be origin only (https://yourref.supabase.co) — no /rest/v1 path.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co

EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key



# Native Google Sign-In — Supabase `signInWithIdToken` flow (NOT Firebase Auth SDK).
#
# 1) EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID = OAuth client type **Web application** (NOT Android/iOS).
#    Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web client.
#
# 2) Android DEVELOPER_ERROR fix: register SHA-1 + SHA-256 for package **com.truwell.ai** on the
#    **Android** OAuth client (same Google Cloud / Firebase project). Get fingerprints:
#      eas credentials -p android   (EAS dev/preview/production keystores)
#      keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android -keypass android
#    After adding SHA, wait ~5 min, then rebuild native app (expo prebuild --clean + eas build).
#
# 3) iOS: set EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID (iOS OAuth client). app.config.ts derives iosUrlScheme for the plugin.
#
# 4) Supabase Dashboard → Authentication → Providers → Google: enable + paste same Web client ID + secret.
#
# 5) Cannot use Expo Go — requires dev client / EAS build (`expo-dev-client` is in this project).
#
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789-yyyy.apps.googleusercontent.com



# Stripe PaymentSheet / telehealth card flows only. In-app subscriptions use Adapty (lib/adapty.ts).

# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx



# Set to 1 only for local Supabase / LAN (http + private IPs allowed in dev). Never in production EAS.

# EXPO_PUBLIC_ALLOW_LOCAL_SUPABASE=1



# In-app subscriptions: Adapty public SDK key is in lib/adapty.ts (not env-based today).

# Dev-only: unlock premium gates for app review (never true in production EAS).
# EXPO_PUBLIC_TEST_MODE=true

